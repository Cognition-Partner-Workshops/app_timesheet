# =============================================================================
# Live Avatar Streaming System - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# -----------------------------------------------------------------------------
# LiveKit Configuration (Self-Hosted)
# -----------------------------------------------------------------------------
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# -----------------------------------------------------------------------------
# STT - Whisper Configuration
# -----------------------------------------------------------------------------
# Use "local" for local Whisper model or "api" for OpenAI Whisper API
WHISPER_MODE=local
# Model size: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=large-v3
# OpenAI API key (only needed if WHISPER_MODE=api)
OPENAI_API_KEY=your_openai_api_key

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# Provider: openai, anthropic
LLM_PROVIDER=openai
# Model name
LLM_MODEL=gpt-4o
# API Keys
# OPENAI_API_KEY is shared with Whisper above
ANTHROPIC_API_KEY=your_anthropic_api_key

# -----------------------------------------------------------------------------
# TTS - Azure Speech Services
# -----------------------------------------------------------------------------
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=westeurope
# Voice names for each language
AZURE_TTS_VOICE_AR=ar-SA-HamedNeural
AZURE_TTS_VOICE_EN=en-US-JennyNeural

# -----------------------------------------------------------------------------
# Avatar Configuration
# -----------------------------------------------------------------------------
# Path to the reference avatar image
AVATAR_IMAGE_PATH=assets/avatar_reference.png
# MuseTalk model directory
MUSETALK_MODEL_DIR=models/musetalk

# -----------------------------------------------------------------------------
# Performance Settings
# -----------------------------------------------------------------------------
# Target FPS for avatar rendering
TARGET_FPS=25
# Enable FP16 for faster inference
USE_FP16=true
# Enable torch.compile optimization
USE_TORCH_COMPILE=true
# Max concurrent sessions (single GPU)
MAX_SESSIONS=1

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO
