# Database credentials (used by docker-compose and backend)
POSTGRES_DB=stockmarket
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/stockmarket

# Redis
REDIS_URL=redis://localhost:6379

# Stock Data API — Twelve Data (primary, free)
# Get a free API key at https://twelvedata.com (takes 10 seconds, free forever)
# The 'demo' key works only for AAPL; get your own for all stocks
TWELVE_DATA_API_KEY=demo

# Alpha Vantage (secondary/fallback)
# Get a free API key at https://www.alphavantage.co/support/#api-key
STOCK_API_KEY=

# Data Mode:
#   USE_MOCK_DATA=true  → generates random data (no API needed, works offline)
#   USE_MOCK_DATA=false → fetches live data from Twelve Data / Alpha Vantage
USE_MOCK_DATA=false

# Backend port
PORT=3001

# CORS allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:3000

# Frontend API base URL (for Vite proxy override)
VITE_API_BASE_URL=/api
