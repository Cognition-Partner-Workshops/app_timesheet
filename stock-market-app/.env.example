# Database credentials (used by docker-compose and backend)
POSTGRES_DB=stockmarket
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/stockmarket

# Redis
REDIS_URL=redis://localhost:6379

# Stock Data API (Alpha Vantage)
# Get a free API key at https://www.alphavantage.co/support/#api-key
STOCK_API_KEY=

# Mock Data Mode — set to "true" to run without a real API key
USE_MOCK_DATA=true

# Backend port
PORT=3001

# CORS allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:3000

# Frontend API base URL (for Vite proxy override)
VITE_API_BASE_URL=/api
