# AI Threat Intelligence Framework - Environment Configuration
# Copy this file to .env and fill in your values.

# General
THREAT_INTEL_ENVIRONMENT=development
THREAT_INTEL_DEBUG=false
THREAT_INTEL_LOG_LEVEL=INFO

# API Server
THREAT_INTEL_API_HOST=0.0.0.0
THREAT_INTEL_API_PORT=8000
THREAT_INTEL_API_PREFIX=/api/v1

# Database
THREAT_INTEL_DATABASE_URL=sqlite+aiosqlite:///./data/threat_intel.db

# OpenAI LLM Configuration
THREAT_INTEL_OPENAI_API_KEY=your-openai-api-key-here
THREAT_INTEL_OPENAI_MODEL=gpt-4
THREAT_INTEL_OPENAI_TEMPERATURE=0.1
THREAT_INTEL_OPENAI_MAX_TOKENS=4096

# Azure OpenAI (optional, set LLM_PROVIDER=azure_openai to use)
# THREAT_INTEL_LLM_PROVIDER=azure_openai
# THREAT_INTEL_AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
# THREAT_INTEL_AZURE_OPENAI_API_KEY=your-azure-key
# THREAT_INTEL_AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# NVD API (optional, increases rate limits)
# THREAT_INTEL_NVD_API_KEY=your-nvd-api-key

# GitHub Advisory API (optional)
# THREAT_INTEL_GITHUB_TOKEN=your-github-token

# Redis / Celery (for async task processing)
THREAT_INTEL_REDIS_URL=redis://localhost:6379/0
THREAT_INTEL_CELERY_BROKER_URL=redis://localhost:6379/1
THREAT_INTEL_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Scanner Configuration
THREAT_INTEL_SCAN_BATCH_SIZE=50
THREAT_INTEL_SCAN_MAX_FILE_SIZE_KB=500
